+3. score=0.226, sigma=2.0, order_bonus=1.5, resource_sd=0.0, beta=2.2, lapse=0.05, overall=0.851, learned=0.915, nonlearned=0.826, c80=0.935, c100=0.714, self=1.000, tau=0.644, bimodal_pairs=10
