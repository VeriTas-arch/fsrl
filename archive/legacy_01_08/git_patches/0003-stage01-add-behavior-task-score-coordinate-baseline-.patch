+        subject_scale=args.subject_scale,
+        update_scale=args.update_scale,
+        eval_beta_override=args.eval_beta_override,
+        memory_mode=args.memory_mode,
+        forget_rate=args.forget_rate,
+        memory_capacity=args.memory_capacity,
+        memory_encoding_noise=args.memory_encoding_noise,
+        eval_memory_encoding_noise=args.eval_memory_encoding_noise,
+        memory_attention_bias=args.memory_attention_bias,
+        distance_salience=args.distance_salience,
