++# Rank-space pairs from Liu/Wang/Luo behavioral task.
++# We use ranks 0..7 from low to high, so (0, 5) means A-F and the signed
++# distance for the oriented pair (A, F) is +5/7.
++PAPER_LEARNING_PAIRS_RANK = [
++    (0, 5),  # A-F
++    (1, 2),  # B-C
++    (1, 4),  # B-E
++    (2, 6),  # C-G
++    (3, 5),  # D-F
++    (3, 6),  # D-G
++    (4, 7),  # E-H
++    (0, 7),  # A-H
++]
